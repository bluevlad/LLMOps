# LLMOps — 환경변수 예제
# 실제 값은 .env (gitignore 됨) 또는 docker-compose 환경변수로 주입

# --- App ---
APP_ENV=dev                       # dev / staging / prod
APP_DEBUG=true
APP_TZ=Asia/Seoul

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=9110
BACKEND_CORS_ORIGINS=http://localhost:4110,https://llmops.unmong.com

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:9110
VITE_GOOGLE_CLIENT_ID=             # Google Identity Services 버튼 (백엔드 GOOGLE_OAUTH_CLIENT_ID 와 동일)

# --- Database (PostgreSQL 공유 컨테이너) ---
# 컨테이너 내: host=postgresql (database-network)
# 로컬: host=localhost (5432 호스트 노출)
DATABASE_URL=postgresql+asyncpg://llmops_svc:CHANGE_ME@localhost:5432/llmops_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Google OAuth (ID Token flow) ---
# llmops.unmong.com 으로 등록된 OAuth Client 사용
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_REDIRECT_URI=https://llmops.unmong.com/auth/callback

# --- LLM Sources (Phase 1b 이후) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
MLX_MODEL_DIR=/Users/rainend/.cache/huggingface/hub
POLLER_OLLAMA_INTERVAL_SECONDS=600   # 10분
POLLER_MLX_INTERVAL_SECONDS=3600     # 1시간

# --- LLMOps API Keys (consumer 서비스 → batch_runs 보고용, Phase 2 이후) ---
# 형식: consumer_id:api_key (JSON object 또는 base64 등 — Phase 1b 에서 확정)
LLMOPS_INGEST_KEYS={}
